# Supabase (instancia AlquiloYa o cualquier proyecto Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Configuración de instancia NEURA
# NEURA_INSTANCE_MODE: "multi_client" (default si no se setea) | "single_client"
# NEURA_CLIENT_SCHEMA: schema PostgREST de la instancia (default "zentra_erp")
# NEURA_CLIENT_NAME:   nombre humano para branding/UI
NEURA_INSTANCE_MODE=single_client
NEURA_CLIENT_SCHEMA=alquiloya
NEURA_CLIENT_NAME=AlquiloYa

# Hosts públicos que sirven la web legacy AlquiloYa en "/"
# (coma-separados, sin protocolo ni puerto). Si el header `host` matchea,
# el middleware reescribe "/" -> "/alquiloya-legacy/index.html".
NEURA_PUBLIC_HOSTS=alquiloya.com.py,www.alquiloya.com.py
